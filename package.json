{
  "name": "ace-desktop",
  "productName": "ACE",
  "version": "0.1.0",
  "description": "ACE Desktop — control plane for the Actualize Coherence Engine",
  "main": "main.js",
  "scripts": {
    "postinstall": "electron-rebuild -f -w node-pty,better-sqlite3",
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "start:debug": "env -u ELECTRON_RUN_AS_NODE electron --inspect=5858 .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "@electron/rebuild": "3.6.0",
    "electron": "28.3.3",
    "electron-builder": "24.13.3"
  },
  "dependencies": {
    "@xterm/addon-fit": "0.11.0",
    "better-sqlite3": "9.4.3",
    "chokidar": "3.6.0",
    "d3": "^7.9.0",
    "dompurify": "^3.3.3",
    "marked": "9.1.6",
    "node-pty": "1.0.0",
    "xterm": "5.3.0"
  },
  "build": {
    "appId": "io.asraya.ace-desktop",
    "productName": "ACE Desktop",
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg",
      "icon": "assets/ace.icns"
    },
    "extraResources": [
      {
        "from": "../tools/ace-analytics",
        "to": "ace-analytics"
      }
    ]
  }
}
